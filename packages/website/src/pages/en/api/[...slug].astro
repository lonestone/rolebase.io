---
import { getCollection, render } from 'astro:content'
import ApiReference from '../../../components/ApiReference.astro'
import DocPage from '../../../components/DocPage.astro'

export async function getStaticPaths() {
  const entries = await getCollection('api', (e) => e.id.endsWith('/en'))
  return entries.map((entry) => {
    const slug = entry.id.replace('/en', '')
    return {
      params: { slug: slug === 'index' ? undefined : slug },
      props: { entry },
    }
  })
}

const { entry } = Astro.props
const { Content } = await render(entry)
const isEntityPage = !!entry.data.entity
---

{isEntityPage ? (
  <ApiReference title={entry.data.title} entity={entry.data.entity!} description={entry.data.description}>
    <Content />
  </ApiReference>
) : (
  <DocPage title={entry.data.title} section="api" description={entry.data.description}>
    <Content />
  </DocPage>
)}
