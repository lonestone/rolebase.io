---
import { getCollection, render } from 'astro:content'
import GuidePage from '../../../components/GuidePage.astro'

export async function getStaticPaths() {
  const entries = await getCollection('guides', (e) => e.id.endsWith('/fr'))
  return entries.map((entry) => {
    const slug = entry.id.replace('/fr', '')
    return {
      params: { slug: slug === 'index' ? undefined : slug },
      props: { entry },
    }
  })
}

const { entry } = Astro.props
const { Content } = await render(entry)
---

<GuidePage title={entry.data.title} section="guides" description={entry.data.description}>
  <Content />
</GuidePage>
