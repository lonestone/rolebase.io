---
import Button from './Button.astro'
import { getLocaleFromPath, translations } from '../i18n'

interface Props {
  name: string
  logo: string
  url: string
}

const { name, logo, url } = Astro.props
const locale = getLocaleFromPath(Astro.url.pathname)
const t = translations[locale]
---

<div
  class="not-prose flex flex-col sm:flex-row items-center gap-8 rounded-2xl border border-gray-200 bg-white p-8"
>
  <div class="flex-shrink-0 flex items-center justify-center w-full sm:w-48 h-24">
    <img
      src={logo}
      alt={name}
      class="max-h-full max-w-full object-contain"
    />
  </div>
  <div class="flex-1 text-center sm:text-left">
    <h2 class="text-xl font-semibold mb-2">{name}</h2>
    <p class="text-text-secondary mb-4">
      <slot />
    </p>
    <Button href={url} variant="outline-primary" size="sm" target="_blank" rel="noopener noreferrer">
      {t.partnersVisitWebsite}
    </Button>
  </div>
</div>
