---
interface Props {
  videoId: string
  aspect?: string
  class?: string
}

const { videoId, aspect = '16/9', class: className } = Astro.props
---

<div
  class:list={["relative overflow-hidden rounded-2xl cursor-pointer group bg-gray-900", className]}
  style={`aspect-ratio: ${aspect}`}
  data-video-trigger
  data-video-id={videoId}
>
  <img
    src={`https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`}
    alt=""
    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
  />
  <div class="absolute inset-0 flex items-center justify-center">
    <svg
      class="w-17 h-12 opacity-80 group-hover:opacity-100 transition-opacity"
      viewBox="0 0 68 48"
    >
      <path
        d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z"
        fill="red"></path>
      <path d="M45 24L27 14v20" fill="white"></path>
    </svg>
  </div>
  <div
    class="hidden absolute inset-0 rounded-2xl overflow-hidden"
    data-video-embed
  >
    <iframe
      class="w-full h-full"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen></iframe>
  </div>
</div>

<script>
  function initYouTubeEmbeds() {
    document.querySelectorAll("[data-video-trigger]").forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const videoId = (trigger as HTMLElement).dataset.videoId
        const embed = trigger.querySelector("[data-video-embed]")
        const iframe = embed?.querySelector("iframe")
        if (iframe && videoId && embed) {
          iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`
          embed.classList.remove("hidden")
        }
      })
    })
  }

  initYouTubeEmbeds()
  document.addEventListener("astro:page-load", initYouTubeEmbeds)
</script>
