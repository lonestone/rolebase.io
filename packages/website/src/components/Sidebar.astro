---
import { translations, getLocaleFromPath } from '../i18n'
import NavLink from './NavLink.astro'

interface Props {
  section: 'docs' | 'guides' | 'developers' | 'api'
}

const { section } = Astro.props

const locale = getLocaleFromPath(Astro.url.pathname)
const t = translations[locale]
---

<aside class="hidden md:block w-65 min-w-65 border-r border-border p-6 pr-4 bg-bg-secondary h-[calc(100vh-56px)] overflow-y-auto sticky top-14" data-sidebar>
  <nav>
    {(section === 'docs' || section === 'guides') && (
      <>
        <div class="mb-6">
          <h3 class="text-xs uppercase tracking-wide text-text-secondary mb-2 border-none p-0">{t.documentation}</h3>
          <div class="flex flex-col">
            {t.docsLinks.map(link => (
              <NavLink exact path={link.slug ? `/docs/${link.slug}` : '/docs'}>{link.label}</NavLink>
            ))}
          </div>
        </div>
        <div class="mb-6">
          <h3 class="text-xs uppercase tracking-wide text-text-secondary mb-2 border-none p-0">{t.guides}</h3>
          <div class="flex flex-col">
            {t.guidesLinks.map(link => (
              <NavLink exact path={`/guides/${link.slug}`}>{link.label}</NavLink>
            ))}
          </div>
        </div>
      </>
    )}

    {section === 'developers' && (
      <div class="mb-6">
        <h3 class="text-xs uppercase tracking-wide text-text-secondary mb-2 border-none p-0">{t.developers}</h3>
        <div class="flex flex-col">
          {t.developersLinks.map(link => (
            <NavLink exact path={link.slug ? `/developers/${link.slug}` : '/developers'}>{link.label}</NavLink>
          ))}
        </div>
      </div>
    )}

    {section === 'api' && (
      <div class="mb-6">
        <h3 class="text-xs uppercase tracking-wide text-text-secondary mb-2 border-none p-0">{t.apiReference}</h3>
        {t.apiLinks.map(link => (
          <NavLink exact path={link.slug ? `/api/${link.slug}` : '/api'}>{link.label}</NavLink>
        ))}

        <h4 class="text-xs text-text-secondary mt-3 mb-1 font-medium">{t.orgMembers}</h4>
        <div class="flex flex-col">
          {[
            { path: '/api/org', label: 'org' },
            { path: '/api/member', label: 'member' },
            { path: '/api/org_file', label: 'org_file' },
            { path: '/api/org_subscription', label: 'org_subscription' },
          ].map(link => (
            <NavLink exact path={link.path} code>{link.label}</NavLink>
          ))}
        </div>

        <h4 class="text-xs text-text-secondary mt-3 mb-1 font-medium">{t.circlesRoles}</h4>
        <div class="flex flex-col">
          {[
            { path: '/api/circle', label: 'circle' },
            { path: '/api/circle_leader', label: 'circle_leader' },
            { path: '/api/circle_link', label: 'circle_link' },
            { path: '/api/circle_member', label: 'circle_member' },
            { path: '/api/circle_participant', label: 'circle_participant' },
            { path: '/api/role', label: 'role' },
          ].map(link => (
            <NavLink exact path={link.path} code>{link.label}</NavLink>
          ))}
        </div>

        <h4 class="text-xs text-text-secondary mt-3 mb-1 font-medium">{t.meetings}</h4>
        <div class="flex flex-col">
          {[
            { path: '/api/meeting', label: 'meeting' },
            { path: '/api/meeting_attendee', label: 'meeting_attendee' },
            { path: '/api/meeting_recurring', label: 'meeting_recurring' },
            { path: '/api/meeting_step', label: 'meeting_step' },
            { path: '/api/meeting_template', label: 'meeting_template' },
          ].map(link => (
            <NavLink exact path={link.path} code>{link.label}</NavLink>
          ))}
        </div>

        <h4 class="text-xs text-text-secondary mt-3 mb-1 font-medium">{t.tasks}</h4>
        <div class="flex flex-col">
          {[
            { path: '/api/task', label: 'task' },
            { path: '/api/task_view', label: 'task_view' },
          ].map(link => (
            <NavLink exact path={link.path} code>{link.label}</NavLink>
          ))}
        </div>

        <h4 class="text-xs text-text-secondary mt-3 mb-1 font-medium">{t.threads}</h4>
        <div class="flex flex-col">
          {[
            { path: '/api/thread', label: 'thread' },
            { path: '/api/thread_activity', label: 'thread_activity' },
            { path: '/api/thread_activity_reaction', label: 'thread_activity_reaction' },
            { path: '/api/thread_extra_member', label: 'thread_extra_member' },
            { path: '/api/thread_poll_answer', label: 'thread_poll_answer' },
          ].map(link => (
            <NavLink exact path={link.path} code>{link.label}</NavLink>
          ))}
        </div>

        <h4 class="text-xs text-text-secondary mt-3 mb-1 font-medium">{t.other}</h4>
        <div class="flex flex-col">
          {[
            { path: '/api/decision', label: 'decision' },
            { path: '/api/news', label: 'news' },
            { path: '/api/log', label: 'log' },
            { path: '/api/users', label: 'users' },
            { path: '/api/api_key', label: 'api_key' },
            { path: '/api/user_app', label: 'user_app' },
            { path: '/api/file', label: 'file' },
          ].map(link => (
            <NavLink exact path={link.path} code>{link.label}</NavLink>
          ))}
        </div>
      </div>
    )}
  </nav>
</aside>
