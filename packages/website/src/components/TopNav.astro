---
import { translations, getLocaleFromPath, getOtherLocaleHref, localePath } from '../i18n'
import Logo from './Logo.astro'
import Button from './Button.astro'

const currentPath = Astro.url.pathname
const locale = getLocaleFromPath(currentPath)
const t = translations[locale]
const otherLocaleHref = getOtherLocaleHref(currentPath, locale)

const isDocumentation = currentPath.includes('/docs')
const isGuides = currentPath.includes('/guides')
const isBlog = currentPath.includes('/blog')

const lp = (path: string) => localePath(locale, path)

interface Props {
  staticHeader?: boolean
}

const { staticHeader = false } = Astro.props

const navLinkClass = (active: boolean) => [
  'px-3 py-1.5 rounded-md text-sm font-medium no-underline hover:no-underline',
  active ? 'bg-primary text-white' : 'text-text-secondary hover:bg-bg-secondary hover:text-text-main',
]
---

<header class:list={["flex items-center justify-between px-6 h-14 border-b border-border bg-white z-50", staticHeader ? '' : 'sticky top-0']}>
  <div class="flex items-center gap-8">
    <a href={lp('')} class="no-underline hover:no-underline"><Logo class="h-6" /></a>
    <nav class="flex gap-1">
      <a href={lp('/docs')} class:list={navLinkClass(isDocumentation)}>{t.documentation}</a>
      <a href={lp('/guides/run-your-first-meeting')} class:list={navLinkClass(isGuides)}>{t.guides}</a>
      <a href={lp('/blog')} class:list={navLinkClass(isBlog)}>{t.blog}</a>
    </nav>
  </div>
  <div class="flex items-center gap-3">
    <a
      href={otherLocaleHref}
      class="text-xs font-semibold px-2 py-0.5 border border-border rounded text-text-secondary no-underline hover:no-underline hover:bg-border"
    >{t.switchLang}</a>
    <Button href={lp('/contact')} variant="outline-primary" size="sm">{t.bookDemo}</Button>
    <Button href="https://rolebase.io/login" variant="primary" size="sm">{t.login}</Button>
  </div>
</header>
