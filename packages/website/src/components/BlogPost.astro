---
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'
import BlogLayout from '../layouts/BlogLayout.astro'
import BlogSidebar from './BlogSidebar.astro'
import BlogCard from './BlogCard.astro'
import InlineCta from './InlineCta.astro'
import TellaVideo from './TellaVideo.astro'
import LoomVideo from './LoomVideo.astro'
import Youtube from './Youtube.astro'
import { type Locale, translations, getSlugFromId } from '../i18n'

interface Props {
  post: CollectionEntry<'blog'>
  locale: Locale
}

const { post, locale } = Astro.props
const t = translations[locale]
const { Content, headings } = await render(post)
const dateLocale = locale === 'fr' ? 'fr-FR' : 'en-US'

const similarSlugs = post.data.similarPosts ?? []
let similarPosts: CollectionEntry<'blog'>[] = []
if (similarSlugs.length > 0) {
  const allPosts = await getCollection('blog', (p) => p.id.endsWith(`/${locale}`))
  similarPosts = similarSlugs
    .map((slug) => allPosts.find((p) => getSlugFromId(p.id) === slug))
    .filter((p): p is CollectionEntry<'blog'> => !!p)
}
---

<BlogLayout title={post.data.title}>
  <article class="min-w-0 flex-1">
    <header class="mb-10 pb-6 border-b border-gray-100">
      <h1 class="mb-4 font-medium text-3xl md:text-4xl lg:text-5xl">
        {post.data.title}
      </h1>
      <p class="text-lg text-gray-500 mb-4">{post.data.summary}</p>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-400">
        {post.data.date && (
          <p>
            {post.data.date.toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' })}
          </p>
        )}
        {post.data.author && (
          <p>{post.data.author}</p>
        )}
      </div>
      {post.data.update && (
        <p class="mt-1 text-sm text-gray-400">
          {t.updatedOn} {post.data.update.toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
      )}
    </header>
    <div class="prose">
      <Content components={{ TellaVideo, LoomVideo, Youtube }} />
    </div>

  </article>
  <aside class="md:w-80 md:shrink-0 lg:w-88">
    <BlogSidebar headings={headings} image={post.data.image} />
  </aside>
  <InlineCta />
  {similarPosts.length > 0 && (
    <section slot="after" class="mt-16 pt-10 border-t border-gray-100">
      <h2 class="text-2xl font-medium mb-8">{t.similarPosts}</h2>
      <div class="not-prose grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {similarPosts.map((p) => (
          <BlogCard post={p} locale={locale} />
        ))}
      </div>
    </section>
  )}
</BlogLayout>
