---
import DocsLayout from './DocsLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import { getLangFromUrl, getTranslations, langPath } from '../i18n'

interface Props {
  title: string
  entity: string
  description?: string
}

const { title, entity, description } = Astro.props
const lang = getLangFromUrl(Astro.url)
const t = await getTranslations(lang)
---

<DocsLayout title={title} section="api">
  <article>
    <header class="mb-8">
      <Breadcrumb category={t.api.reference} categoryUrl={langPath(lang, '/api')} title={title} hideTitle class="mb-3" />
      <span class="inline-block bg-gray-800 text-white text-xs px-2.5 py-0.5 rounded font-semibold uppercase tracking-wide">{t.api.reference}</span>
      <h1 class="mt-1 text-4xl font-bold font-mono"><code class="text-[1em] bg-transparent p-0">{entity}</code></h1>
      {description && <p class="text-lg text-text-secondary">{description}</p>}
    </header>
    <div>
      <slot />
    </div>
  </article>
</DocsLayout>
