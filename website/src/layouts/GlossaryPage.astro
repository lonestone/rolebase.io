---
import type { CollectionEntry } from 'astro:content'
import { render } from 'astro:content'
import BlogLayout from './BlogLayout.astro'
import BlogSidebar from '../components/BlogSidebar.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import { mdxComponents } from '../components'
import { type Lang, getTranslations, langPath } from '../utils/i18n'

interface Props {
  item: CollectionEntry<'glossary'>
  lang: Lang
}

const { item, lang } = Astro.props
const t = await getTranslations(lang)
const { Content, headings } = await render(item)
const dateLang = lang === 'fr' ? 'fr-FR' : 'en-US'
---

<BlogLayout title={`${item.data.name} - ${t.glossary.definition}`} description={item.data.description}>
  <article class="min-w-0 flex-1">
    <header class="mb-10 pb-6 border-b border-gray-100">
      <Breadcrumb category={t.glossary.label} categoryUrl={langPath(lang, '/glossary')} title={item.data.name} hideTitle class="mb-3" />
      <h1 class="mb-4 font-medium text-3xl md:text-4xl lg:text-5xl">
        {item.data.name}
      </h1>
      <p class="text-lg text-gray-500 mb-4">{item.data.summary}</p>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-400">
        {item.data.date && (
          <p>
            {item.data.date.toLocaleDateString(dateLang, { year: 'numeric', month: 'long', day: 'numeric' })}
          </p>
        )}
      </div>
      {item.data.update && item.data.update.getTime() !== item.data.date?.getTime() && (
        <p class="mt-1 text-sm text-gray-400">
          {t.updatedOn} {item.data.update.toLocaleDateString(dateLang, { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
      )}
    </header>
    <div>
      <Content components={mdxComponents} />
    </div>
  </article>
  <aside class="md:w-80 md:shrink-0 lg:w-88">
    <BlogSidebar headings={headings} />
  </aside>
</BlogLayout>
