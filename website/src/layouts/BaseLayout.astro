---
import TopNav from '../components/TopNav.astro'
import TopNavDev from '../components/TopNavDev.astro'
import Footer from '../components/Footer.astro'
import { getLocaleFromPath } from '../i18n'
import '../styles/global.css'

interface Props {
  title: string
  staticHeader?: boolean
}

const { title, staticHeader = false } = Astro.props
const currentPath = Astro.url.pathname
const locale = getLocaleFromPath(currentPath)
const isDevSection = currentPath.includes('/developers') || currentPath.includes('/api')
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - Rolebase</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {import.meta.env.PROD && (
      <script
        defer
        src="https://umami.internal.lonestone.io/script.js"
        data-website-id="b551cd9c-5426-410a-83ed-94d46b6a7865"></script>
    )}
  </head>
  <body class="min-h-dvh flex flex-col">
    {isDevSection ? <TopNavDev /> : <TopNav staticHeader={staticHeader} />}
    <div class="flex-1 flex flex-col">
      <slot />
    </div>
    <Footer />
  </body>
</html>
