---
import { getCollection } from 'astro:content'
import WebsiteLayout from './WebsiteLayout.astro'
import { type Locale, translations, getSlugFromId } from '../i18n'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const t = translations[locale]
const basePath = `/${locale}/glossary`

const items = (await getCollection('glossary', (item) => item.id.endsWith(`/${locale}`) && !item.data.draft))
  .sort((a, b) => a.data.name.localeCompare(b.data.name, locale))
---

<WebsiteLayout title={t.glossary}>
  <div class="mb-10">
    <h1 class="text-4xl font-bold mb-3">{t.glossary}</h1>
    <p class="text-lg text-text-secondary">{t.glossarySubtitle}</p>
  </div>

  <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
    {items.map((item) => (
      <a
        href={`${basePath}/${getSlugFromId(item.id)}`}
        class="group block overflow-hidden rounded-2xl border border-gray-200 bg-white transition-all hover:border-primary hover:shadow-lg no-underline p-5"
      >
        <h2 class="text-lg font-medium leading-snug group-hover:text-primary transition-colors">
          {item.data.name}
        </h2>
        <p class="mt-2 text-sm text-text-secondary line-clamp-3">{item.data.summary}</p>
      </a>
    ))}
  </div>
</WebsiteLayout>
