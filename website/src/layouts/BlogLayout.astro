---
import BaseLayout from './BaseLayout.astro'

interface Props {
  title: string
}

const { title } = Astro.props
---

<BaseLayout title={title} staticHeader>
  <main class="max-w-6xl mx-auto px-6 py-16">
    <div class="flex flex-col gap-8 md:flex-row lg:gap-12">
      <slot />
    </div>
    <slot name="after" />
  </main>
</BaseLayout>
