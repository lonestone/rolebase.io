---
import { getCollection } from 'astro:content'
import ClientCasePage from '../../../components/ClientCasePage.astro'
import type { Locale } from '../../../i18n'

export async function getStaticPaths() {
  const locales: Locale[] = ['en', 'fr']
  const paths = []
  for (const lang of locales) {
    const items = await getCollection('client-cases', (item) => item.id.endsWith(`/${lang}`))
    for (const item of items) {
      paths.push({
        params: { lang, slug: item.id.replace(`/${lang}`, '') },
        props: { item, locale: lang },
      })
    }
  }
  return paths
}

const { item, locale } = Astro.props
---

<ClientCasePage item={item} locale={locale} />
