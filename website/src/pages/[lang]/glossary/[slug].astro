---
import { getCollection } from 'astro:content'
import GlossaryPage from '../../../layouts/GlossaryPage.astro'
import { langs } from '../../../i18n'

export async function getStaticPaths() {
  const paths = []
  for (const lang of langs) {
    const items = await getCollection('glossary', (item) => item.id.endsWith(`/${lang}`) && !item.data.draft)
    for (const item of items) {
      paths.push({
        params: { lang, slug: item.id.replace(`/${lang}`, '') },
        props: { item, lang },
      })
    }
  }
  return paths
}

const { item, lang } = Astro.props
---

<GlossaryPage item={item} lang={lang} />
