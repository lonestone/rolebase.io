---
import { getCollection, render } from 'astro:content'
import ApiReference from '../../../components/ApiReference.astro'
import DocPage from '../../../components/DocPage.astro'
import type { Locale } from '../../../i18n'

export async function getStaticPaths() {
  const locales: Locale[] = ['en', 'fr']
  const paths = []
  for (const lang of locales) {
    const entries = await getCollection('api', (e) => e.id.endsWith(`/${lang}`))
    for (const entry of entries) {
      const slug = entry.id.replace(`/${lang}`, '')
      paths.push({
        params: { lang, slug: slug === 'index' ? undefined : slug },
        props: { entry },
      })
    }
  }
  return paths
}

const { entry } = Astro.props
const { Content } = await render(entry)
const isEntityPage = !!entry.data.entity
---

{isEntityPage ? (
  <ApiReference title={entry.data.title} entity={entry.data.entity!} description={entry.data.description}>
    <Content />
  </ApiReference>
) : (
  <DocPage title={entry.data.title} section="api" description={entry.data.description}>
    <Content />
  </DocPage>
)}
