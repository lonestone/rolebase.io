---
import { translations, getLocaleFromPath } from '../i18n'
import TopNavShell from './TopNavShell.astro'
import NavLink from './NavLink.astro'

const locale = getLocaleFromPath(Astro.url.pathname)
const t = translations[locale]
---

<TopNavShell logoSuffix={t.developers}>
  <Fragment slot="nav">
    <NavLink path="/developers">{t.documentation}</NavLink>
    <NavLink path="/api">{t.apiReference}</NavLink>
  </Fragment>
</TopNavShell>
