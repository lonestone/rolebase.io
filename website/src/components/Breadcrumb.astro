---
interface Props {
  category: string
  categoryUrl: string
  title: string
  hideTitle?: boolean
  class?: string
}

const {
  category,
  categoryUrl,
  title,
  hideTitle = false,
  class: className,
} = Astro.props

const linkClass = 'text-text-secondary hover:text-text-main hover:underline transition-colors'
---

<nav class:list={['text-sm text-text-secondary', className]}>
  <a href="/" class={linkClass}>Rolebase</a>
  <span class="mx-1">⟩</span>
  <a href={categoryUrl} class={linkClass}>{category}</a>
  {!hideTitle && (
    <>
      <span class="mx-1">⟩</span>
      <span>{title}</span>
    </>
  )}
</nav>

<script is:inline type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Rolebase",
      item: `${Astro.site?.origin ?? ''}/`,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: category,
      item: `${Astro.site?.origin ?? ''}${categoryUrl}`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: title,
      item: `${Astro.site?.origin ?? ''}${Astro.url.pathname.replace(/\.html$/, '')}`,
    },
  ],
})} />
