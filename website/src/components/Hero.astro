---
import Button from './Button.astro'
import CirclesAnimation from './CirclesAnimation.astro'

interface Props {
  title: string
  subtitle: string
  buttonText: string
  buttonHref: string
  smallText: string
}

const { title, subtitle, buttonText, buttonHref, smallText } = Astro.props
---

<section class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
  <div class="flex-1">
    <h1 class="text-4xl md:text-5xl font-bold leading-tight mt-0 mb-0">{title}</h1>
    <p class="mt-6 text-lg text-text-secondary">{subtitle}</p>
    <div class="mt-8">
      <Button href={buttonHref} label={buttonText} />
      <p class="mt-2 text-sm text-text-secondary">{smallText}</p>
    </div>
    <div class="flex items-center gap-4 mt-6 [&_p]:mb-0! [&_p]:contents [&_img]:h-20 [&_img]:w-auto">
      <slot />
    </div>
  </div>
  <div class="flex-1">
    <CirclesAnimation class="w-full" />
  </div>
</section>
