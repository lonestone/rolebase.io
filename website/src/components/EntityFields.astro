---
import { getLangFromUrl, getTranslations } from '../utils/i18n'

interface Field {
  name: string
  type: string
  description: string
}

interface Props {
  fields: Field[]
}

const { fields } = Astro.props
const lang = getLangFromUrl(Astro.url)
const t = await getTranslations(lang)
---

<table class="my-8 w-full border-collapse text-sm">
  <thead>
    <tr>
      <th class="border-b-2 border-gray-200 bg-gray-50 px-5 py-3 text-left text-base font-semibold">{t.api.fieldLabel}</th>
      <th class="border-b-2 border-gray-200 bg-gray-50 px-5 py-3 text-left text-base font-semibold">{t.api.typeLabel}</th>
      <th class="border-b-2 border-gray-200 bg-gray-50 px-5 py-3 text-left text-base font-semibold">{t.api.descriptionLabel}</th>
    </tr>
  </thead>
  <tbody>
    {fields.map(field => (
      <tr>
        <td class="border-b border-gray-100 px-5 py-3 text-base"><code class="text-sm whitespace-nowrap">{field.name}</code></td>
        <td class="border-b border-gray-100 px-5 py-3 text-base"><code class="text-sm whitespace-nowrap">{field.type}</code></td>
        <td class="border-b border-gray-100 px-5 py-3 text-base">{field.description}</td>
      </tr>
    ))}
  </tbody>
</table>
