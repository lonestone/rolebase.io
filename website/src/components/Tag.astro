---
interface Props {
  variant?: 'outline' | 'solid'
  color?: 'primary' | 'gray' | 'green' | 'yellow' | 'red'
  class?: string
}

const { variant = 'solid', color = 'primary', class: className } = Astro.props

const colorClasses = {
  outline: {
    primary: 'text-primary border-primary',
    gray: 'text-gray-600 border-gray-300',
    green: 'text-green-700 border-green-400',
    yellow: 'text-yellow-700 border-yellow-400',
    red: 'text-red-700 border-red-400',
  },
  solid: {
    primary: 'bg-primary text-white',
    gray: 'bg-gray-200 text-gray-700',
    green: 'bg-green-100 text-green-800',
    yellow: 'bg-yellow-100 text-yellow-800',
    red: 'bg-red-100 text-red-800',
  },
}
---

<span
  class:list={[
    'inline-block px-3 py-1 rounded-full text-sm font-medium',
    variant === 'outline' && 'border',
    colorClasses[variant][color],
    className,
  ]}
>
  <slot />
</span>
