---
import { translations, getLocaleFromPath, localePath } from '../i18n'
import TopNavShell from './TopNavShell.astro'
import NavLink from './NavLink.astro'
import Button from './Button.astro'

const currentPath = Astro.url.pathname
const locale = getLocaleFromPath(currentPath)
const t = translations[locale]
const lp = (path: string) => localePath(locale, path)

interface Props {
  staticHeader?: boolean
}

const { staticHeader = false } = Astro.props
---

<TopNavShell staticHeader={staticHeader}>
  <Fragment slot="nav">
    <NavLink path="/features">{t.features}</NavLink>
    <NavLink path="/client-cases">{t.clientCases}</NavLink>
    <NavLink path="/pricing">{t.pricing}</NavLink>
    <NavLink path="/docs">{t.documentation}</NavLink>
    <NavLink path="/blog">{t.blog}</NavLink>
  </Fragment>
  <Fragment slot="right">
    <Button href={lp('/contact')} variant="outline-primary" size="sm" label={t.bookDemo} />
    <Button href="/login" variant="primary" size="sm" label={t.login} />
  </Fragment>
</TopNavShell>
