---
import { getTranslations, getLangFromUrl, langPath } from '../i18n'
import Icon from './Icon.astro'
import Logo from './Logo.astro'

const lang = getLangFromUrl(Astro.url)
const t = await getTranslations(lang)

const lp = (path: string) => langPath(lang, path)

const linkClass = 'no-underline hover:underline'
---

<footer class="border-t border-border bg-bg-secondary py-12 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8 text-sm text-text-secondary">

      <div class="flex flex-col gap-4">
        <a href={lp('')} class="no-underline hover:no-underline">
          <Logo class="h-6" />
        </a>
        <a
          href="https://github.com/Godefroy/rolebase"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 no-underline hover:underline"
          aria-label="GitHub"
        >
          <Icon icon="github" class="w-5 h-5" />
          GitHub
        </a>
      </div>

      <div class="flex flex-col gap-2">
        <span class="font-medium text-text-main">{t.footer.product}</span>
        <a href={lp('/features')} class={linkClass}>{t.features}</a>
        <a href={lp('/client-cases')} class={linkClass}>{t.clientCases.label}</a>
        <a href={lp('/pricing')} class={linkClass}>{t.pricing}</a>
      </div>

      <div class="flex flex-col gap-2">
        <span class="font-medium text-text-main">{t.footer.comparisons}</span>
        <a href={lp('/blog/alternative-holaspirit')} class={linkClass}>{t.footer.alternatives.holaspirit}</a>
        <a href={lp('/blog/alternative-nestr')} class={linkClass}>{t.footer.alternatives.nestr}</a>
        <a href={lp('/blog/alternative-glassfrog')} class={linkClass}>{t.footer.alternatives.glassfrog}</a>
        <a href={lp('/blog/alternative-peerdom')} class={linkClass}>{t.footer.alternatives.peerdom}</a>
      </div>

      <div class="flex flex-col gap-2">
        <span class="font-medium text-text-main">{t.footer.resources}</span>
        <a href={lp('/docs')} class={linkClass}>{t.documentation}</a>
        <a href={lp('/developers')} class={linkClass}>{t.developers}</a>
        <a href={lp('/glossary')} class={linkClass}>{t.glossary.label}</a>
        <a href="#" class={linkClass} onclick="if(window.$crisp){$crisp.push(['do','chat:open'])}return false">{t.support}</a>
        <a href={lp('/blog')} class={linkClass}>{t.blog.label}</a>
      </div>

      <div class="flex flex-col gap-2">
        <span class="font-medium text-text-main">{t.footer.company}</span>
        <a href={lp('')} class={linkClass}>{t.about}</a>
        <a href={lp('/partners')} class={linkClass}>{t.partners.label}</a>
        <a href={lp('/legal')} class={linkClass}>{t.terms}</a>
        <a href={lp('/privacy')} class={linkClass}>{t.privacyPolicy}</a>
        <a href={lp('/terms')} class={linkClass}>{t.termsOfSale}</a>
      </div>

    </div>
  </div>
</footer>
