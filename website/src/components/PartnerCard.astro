---
import Button from './Button.astro'
import { Image } from 'astro:assets'
import { resolveContentImage, type ImagePath } from '../resolve-image'
import { getLangFromUrl, getTranslations } from '../i18n'

interface Props {
  name: string
  logo: ImagePath
  url: string
}

const { name, logo, url } = Astro.props
const lang = getLangFromUrl(Astro.url)
const t = await getTranslations(lang)

const resolvedImage = await resolveContentImage(logo)
---

<div
  class="flex flex-col sm:flex-row items-center gap-8 rounded-2xl border border-gray-200 bg-white p-8"
>
  <div class="flex-shrink-0 flex items-center justify-center w-full sm:w-48 h-24">
    {resolvedImage ? (
      <Image
        src={resolvedImage}
        alt={name}
        class="max-h-full max-w-full object-contain"
      />
    ) : (
      <img
        src={logo}
        alt={name}
        class="max-h-full max-w-full object-contain"
      />
    )}
  </div>
  <div class="flex-1 text-center sm:text-left">
    <h2 class="text-xl font-semibold mb-2">{name}</h2>
    <p class="text-text-secondary mb-4">
      <slot />
    </p>
    <Button href={url} variant="outline-primary" size="sm" targetBlank label={t.partners.visitWebsite} />
  </div>
</div>
